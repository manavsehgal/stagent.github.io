---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import PersonaLanes from '../components/sections/PersonaLanes.astro';
import Proof from '../components/sections/Proof.astro';
import Pricing from '../components/sections/Pricing.astro';
import PlaybookTeaser from '../components/sections/PlaybookTeaser.astro';
import CTAFooter from '../components/sections/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import { SITE, ORGANIZATION, PUBLISHER } from '../data/seo';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    ...ORGANIZATION,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    publisher: PUBLISHER,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Stagent',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'macOS, Windows, Linux',
    description: SITE.description,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    license: 'https://www.apache.org/licenses/LICENSE-2.0',
    programmingLanguage: ['TypeScript'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is Stagent?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Stagent is the operating system for AI-native business. It orchestrates AI agents across marketing, sales, support, operations, and finance with governed execution, reusable profiles, workflow blueprints, and human-in-the-loop oversight.',
        },
      },
      {
        '@type': 'Question',
        name: 'What makes Stagent different from other AI agent tools?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Stagent is the only platform combining full-stack agent orchestration with enterprise-grade governance. It supports 5 AI runtimes, 21+ specialist agent profiles, 6 workflow patterns, multi-channel delivery, and a local-first architecture that keeps your data on your machine.',
        },
      },
      {
        '@type': 'Question',
        name: 'What technology stack does Stagent use?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Stagent is built with Next.js 16, React 19, TypeScript, Tailwind CSS v4, shadcn/ui, SQLite via Drizzle ORM, and governed runtime integrations for both the Claude Agent SDK and OpenAI Codex App Server.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is Stagent open source?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, the Stagent community edition is fully open source under the Apache 2.0 license.',
        },
      },
    ],
  },
];
---
<Layout jsonLd={jsonLd}>
  <Nav />
  <main>
    <Hero />
    <Problem />
    <PersonaLanes />
    <Proof />
    <Pricing />
    <PlaybookTeaser />
    <CTAFooter />
  </main>
  <Footer />
</Layout>
