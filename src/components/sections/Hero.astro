---
import WaitlistForm from '../ui/WaitlistForm.astro';
import BusinessConstellation from '../svg/BusinessConstellation.astro';
import TechTicker from './TechTicker.astro';
---
<section class="relative min-h-[calc(100dvh-80px)] flex items-center px-6 overflow-x-clip pt-14 pb-24">
  <!-- Dual atmospheric glow -->
  <div class="absolute inset-0 -z-10 flex items-center justify-center pointer-events-none">
    <div class="absolute w-[800px] h-[800px] rounded-full bg-primary/[0.10] blur-[180px]"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-primary/[0.15] blur-[100px]"></div>
  </div>

  <!-- Bottom gradient fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-40 pointer-events-none" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>

  <!-- Two-column grid — diagram-dominant -->
  <div class="relative z-10 w-full max-w-7xl mx-auto grid lg:grid-cols-[1fr_1.75fr] gap-8 lg:gap-10 items-center py-16 lg:py-4">

    <!-- Left column: Content (compact to give diagram more room) -->
    <div class="text-center lg:text-left" data-animate-stagger>

      <h1
        data-animate
        class="hero-gradient-text font-display text-[clamp(1.6rem,3vw,2.3rem)] font-bold leading-[1.15] mb-3"
      >
        The Operating System<br/>for AI-Native Business
      </h1>

      <p
        data-animate
        class="text-[clamp(0.85rem,1.8vw,1.05rem)] text-text-muted leading-relaxed mb-5 mx-auto lg:mx-0 max-w-sm"
      >
        AI agents that grow revenue, cut costs, and govern themselves. Every function automated. Every decision informed. Every risk governed.
      </p>

      <!-- Email CTA -->
      <div data-animate class="my-6 max-w-sm mx-auto lg:mx-0">
        <WaitlistForm
          variant="hero"
          id="hero-waitlist"
          source="hero"
          buttonText="Get Early Access"
        />
      </div>

      <!-- Value proposition pills -->
      <div
        data-animate
        class="flex items-center justify-center lg:justify-start gap-1.5 flex-wrap mb-4"
      >
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">Community Edition</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">Local-First</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">Multi-Model AI</span>
        <span class="font-mono text-[10px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-2.5 py-1">Human-in-the-Loop</span>
      </div>

      <!-- Terminal CTA -->
      <p data-animate class="font-mono text-[10px] tracking-[0.2em] uppercase text-text-muted mt-5 mb-2">
        Try Stagent community edition now
      </p>
      <div data-animate class="max-w-sm mx-auto lg:mx-0">
        <div class="relative border border-primary/30 rounded-lg primary-pulse overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 border-b border-primary/10">
            <span class="font-mono text-[10px] uppercase tracking-widest text-text-muted">Terminal</span>
            <button
              id="hero-copy-btn"
              class="p-1 rounded text-text-muted/50 hover:text-text-muted transition-colors"
              aria-label="Copy to clipboard"
            >
              <svg id="hero-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg id="hero-check-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </button>
          </div>
          <div class="bg-surface-raised px-4 py-3">
            <pre class="font-mono text-lg sm:text-xl leading-relaxed text-text-muted"><span class="text-primary">$</span> <code id="hero-code">npx stagent</code><span class="hero-cursor">▌</span></pre>
          </div>
        </div>
      </div>

    </div>

    <!-- Right column: Architecture diagram -->
    <a href="/research" data-animate class="hero-arch-wrapper block hover:opacity-90 transition-opacity cursor-pointer" style="transition-delay: 200ms" aria-label="View architecture playbook">
      <BusinessConstellation />
    </a>

  </div>

  <TechTicker />
</section>


<style>
  /* ── Gradient text ── */
  .hero-gradient-text {
    background: linear-gradient(135deg, oklch(0.78 0.12 230), var(--color-primary), oklch(0.58 0.18 280));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Blinking cursor ── */
  .hero-cursor {
    animation: hero-blink 1s step-end infinite;
    color: var(--color-primary);
  }
  @keyframes hero-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-cursor { animation: none; }
  }

  /* ── Architecture diagram wrapper — ambient glow only ── */
  .hero-arch-wrapper {
    position: relative;
  }
  .hero-arch-wrapper::after {
    content: '';
    position: absolute;
    inset: -60px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      oklch(0.55 0.15 260 / 0.10) 0%,
      transparent 70%
    );
    z-index: -1;
    pointer-events: none;
  }
</style>

<script>
  function initHeroCopy() {
    document.getElementById('hero-copy-btn')?.addEventListener('click', async () => {
      const code = document.getElementById('hero-code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      const copyIcon = document.getElementById('hero-copy-icon');
      const checkIcon = document.getElementById('hero-check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    });
  }

  initHeroCopy();
  document.addEventListener('astro:after-swap', initHeroCopy);
</script>

