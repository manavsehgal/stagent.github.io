---
import SectionLabel from '../ui/SectionLabel.astro';
import ArchitectureGlance from '../svg/ArchitectureGlance.astro';

const metrics = [
  { value: '102', label: 'Features Shipped' },
  { value: '34', label: 'Operator Surfaces' },
  { value: '5', label: 'AI Runtimes' },
  { value: '52+', label: 'Agent Profiles' },
  { value: '25', label: 'Workflow Patterns' },
];

const quotes = [
  {
    text: 'I am confident that we are going to see the one-person billion-dollar company, enabled by AI agents.',
    author: 'Sam Altman',
    role: 'CEO, OpenAI',
  },
  {
    text: 'I put 70–80% odds on one-person unicorns happening in 2026.',
    author: 'Dario Amodei',
    role: 'CEO, Anthropic',
  },
];
---
<section class="py-24 px-6 bg-surface-raised/50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <SectionLabel text="Proof" />
      <h2 data-animate class="mt-4 mb-4">Not Slideware. Shipped Software.</h2>
      <p data-animate class="text-text-muted" style="transition-delay: 80ms">
        Every feature below is live in the community edition and inspectable on GitHub.
      </p>
    </div>

    <!-- Metric bar -->
    <div data-animate-stagger class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-14">
      {metrics.map(({ value, label }) => (
        <div data-animate class="rounded-xl border border-primary/15 bg-primary/[0.04] p-5 text-center">
          <div class="text-2xl md:text-3xl font-bold text-primary font-mono">{value}</div>
          <div class="text-xs text-text-muted mt-1 font-mono tracking-wider uppercase">{label}</div>
        </div>
      ))}
    </div>

    <!-- Architecture at a glance -->
    <div data-animate class="rounded-xl border border-border/60 bg-surface-raised/50 p-6 md:p-8 mb-14">
      <ArchitectureGlance />
      <div class="mt-4 text-center">
        <a href="/research/#architecture" class="inline-flex items-center gap-1.5 text-primary font-mono text-xs tracking-wider hover:underline">
          See full architecture
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Living Book -->
    <div data-animate class="rounded-xl border border-primary/20 bg-gradient-to-br from-primary/[0.06] to-primary/[0.02] p-6 md:p-8 mb-14">
      <div class="flex flex-col md:flex-row gap-6 items-start">
        <div class="shrink-0 w-16 h-20 rounded-lg bg-primary/15 flex items-center justify-center">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">A Book That Writes Itself</h3>
          <p class="text-text-muted leading-relaxed mb-3">
            The AI Native book — 9 chapters across 3 parts — is generated by Stagent's own document-writer agent. It detects when source code changes and regenerates itself. The product's most compelling proof-of-concept: a book written by the software it describes.
          </p>
          <a href="/book/" class="inline-flex items-center gap-1.5 text-primary font-mono text-xs tracking-wider hover:underline">
            Read the Living Book
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Market validation quotes -->
    <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
      {quotes.map(({ text, author, role }) => (
        <div data-animate class="rounded-xl border border-border bg-surface-raised p-6 border-l-[3px] border-l-primary">
          <p class="text-sm text-text-muted italic leading-relaxed mb-3">"{text}"</p>
          <p class="text-xs font-mono text-text-muted/60">
            <span class="font-semibold text-text-muted">{author}</span> — {role}
          </p>
        </div>
      ))}
    </div>

    <!-- Community edition trust -->
    <p data-animate class="text-center text-xs text-text-muted/60 font-mono">
      Community edition under Apache 2.0 · Every line inspectable on GitHub · Local-first — your data never leaves your machine
    </p>
  </div>
</section>
