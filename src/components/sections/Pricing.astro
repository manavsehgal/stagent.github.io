---
import SectionLabel from '../ui/SectionLabel.astro';

const features = [
  'Unlimited agent memories',
  'Unlimited schedules',
  '365-day history retention',
  'Analytics dashboard',
  '6 AI runtimes',
  '56+ agent profiles',
  '37 workflow patterns',
  'Human-in-the-loop governance',
  'Cost metering & budgets',
  'Multi-channel delivery',
  'Chat with @ mentions',
  'Browser automation',
];
---
<section id="pricing" class="py-24 px-6 scroll-mt-10">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <SectionLabel text="Open Source" />
      <h2 data-animate class="mt-4 mb-4">Everything. Free. No Limits.</h2>
      <p data-animate class="text-text-muted max-w-2xl mx-auto" style="transition-delay: 80ms">
        No tiers, no paywalls, no feature gates. Every capability, unlimited, Apache 2.0.
      </p>
    </div>

    <div data-animate class="rounded-xl border border-primary/30 bg-surface-raised p-8 md:p-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 mb-8">
        {features.map((feature) => (
          <div class="flex items-center gap-2 text-sm text-text-muted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {feature}
          </div>
        ))}
      </div>

      <!-- Terminal CTA -->
      <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-text-muted mb-2 text-center">
        Get started now
      </p>
      <div class="max-w-sm mx-auto">
        <div class="relative border border-primary/30 rounded-lg primary-pulse overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 border-b border-primary/10">
            <span class="font-mono text-[10px] uppercase tracking-widest text-text-muted">Terminal</span>
            <button
              id="pricing-copy-btn"
              class="p-1 rounded text-text-muted/50 hover:text-text-muted transition-colors"
              aria-label="Copy to clipboard"
            >
              <svg id="pricing-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg id="pricing-check-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </button>
          </div>
          <div class="bg-surface-raised px-4 py-3">
            <pre class="font-mono text-lg sm:text-xl leading-relaxed text-text-muted"><span class="text-primary">$</span> <code id="pricing-code">npx stagent</code><span class="hero-cursor">▌</span></pre>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-text-muted/60 mt-4 font-mono">
        Zero config. Local SQLite. Own your data.
      </p>
    </div>
  </div>
</section>

<script>
  function initPricingCopy() {
    document.getElementById('pricing-copy-btn')?.addEventListener('click', async () => {
      const code = document.getElementById('pricing-code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      const copyIcon = document.getElementById('pricing-copy-icon');
      const checkIcon = document.getElementById('pricing-check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    });
  }

  initPricingCopy();
  document.addEventListener('astro:after-swap', initPricingCopy);
</script>
