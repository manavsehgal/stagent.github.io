---
/**
 * BusinessConstellation — Hero visualization
 * Network constellation: 4 inner Stagent product nodes → 6 outer business outcome nodes
 * 3D sphere gradients, galaxy drift, edge-terminated bezier curves, external labels
 */
---
<svg viewBox="0 0 560 400" xmlns="http://www.w3.org/2000/svg" class="bc w-full mx-auto" data-svg-animate>
  <defs>
    <!-- Soft glow filter for Agents hero node -->
    <filter id="bc-glow">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <!-- Lighter glow for prominent outer nodes -->
    <filter id="bc-glow-soft">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- 3D sphere gradients with offset highlight -->
    <radialGradient id="bc-sphere-blue" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-blue)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="bc-sphere-teal" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-teal)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-teal)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-teal)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="bc-sphere-purple" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-purple)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-purple)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-purple)" stop-opacity="0.03"/>
    </radialGradient>
    <radialGradient id="bc-sphere-orange" cx="35%" cy="30%" r="65%">
      <stop offset="0%" stop-color="var(--svg-accent-orange)" stop-opacity="0.45"/>
      <stop offset="50%" stop-color="var(--svg-accent-orange)" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="var(--svg-accent-orange)" stop-opacity="0.03"/>
    </radialGradient>

    <!-- Central atmospheric glow -->
    <radialGradient id="bc-atmo" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="var(--svg-accent-blue)" stop-opacity="0.12"/>
      <stop offset="40%" stop-color="var(--svg-accent-blue)" stop-opacity="0.04"/>
      <stop offset="100%" stop-color="var(--svg-accent-blue)" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <style>
    /* Ambient animations */
    @keyframes bc-dash { to { stroke-dashoffset: -14; } }
    .bc-inner-conn { stroke-dasharray: 3 4; animation: bc-dash 3s linear infinite; }

    /* Galaxy drift keyframes */
    @keyframes bc-drift-1 { 0%,100% { transform: translate(0,0); } 25% { transform: translate(4px,-2px); } 50% { transform: translate(1px,1px); } 75% { transform: translate(-3px,3px); } }
    @keyframes bc-drift-2 { 0%,100% { transform: translate(0,0); } 25% { transform: translate(-3px,2px); } 50% { transform: translate(-1px,-1px); } 75% { transform: translate(2px,-3px); } }
    @keyframes bc-drift-3 { 0%,100% { transform: translate(0,0); } 25% { transform: translate(3px,3px); } 50% { transform: translate(0px,-1px); } 75% { transform: translate(-4px,-1px); } }
    @keyframes bc-drift-4 { 0%,100% { transform: translate(0,0); } 25% { transform: translate(-2px,-3px); } 50% { transform: translate(1px,0px); } 75% { transform: translate(3px,2px); } }
    @keyframes bc-drift-5 { 0%,100% { transform: translate(0,0); } 25% { transform: translate(1.5px,-1px); } 50% { transform: translate(-0.5px,0.5px); } 75% { transform: translate(-1px,1.5px); } }
    @keyframes bc-drift-6 { 0%,100% { transform: translate(0,0); } 25% { transform: translate(-1px,1px); } 50% { transform: translate(0.5px,-0.5px); } 75% { transform: translate(1px,-1.5px); } }

    /* Light mode overrides */
    :global(html[data-theme="light"]) .bc .bc-atmo-circle { opacity: 0.5; }
    :global(html[data-theme="light"]) .bc .bc-particle { opacity: 0.4; }
    :global(html[data-theme="light"]) .bc .bc-watermark { opacity: 0.2; }
    :global(html[data-theme="light"]) .bc .bc-outer-halo { opacity: 0.5; }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .bc-inner-conn { animation: none; }
      .bc .bc-particle { display: none; }
      .bc .bc-halo { animation: none !important; }
      .bc .bc-drift { animation: none !important; }
    }
  </style>

  <!-- ═══ ATMOSPHERE ═══ -->
  <g class="svg-reveal">
    <circle class="bc-atmo-circle" cx="280" cy="200" r="190" fill="url(#bc-atmo)"/>
  </g>

  <!-- ═══ CONNECTIONS: Inner ↔ Outer (edge-terminated bezier curves) ═══ -->
  <g class="svg-reveal svg-reveal-d7">
    <!-- Primary connections (10% opacity, 1px) -->
    <!-- Agents → Revenue Growth -->
    <path id="bc-p-ag-rev" d="M254.4,135.8 Q200,95 138.6,73.3" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Agents → Customer Success -->
    <path id="bc-p-ag-cus" d="M305.6,135.8 Q360,95 424.9,75.9" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Workflows → Operations Excellence -->
    <path id="bc-p-wf-ops" d="M184.1,213.1 Q140,210 88.3,195.2" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Workflows → Cost Efficiency -->
    <path id="bc-p-wf-cost" d="M194.9,236.2 Q160,285 119.9,308.4" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Documents → Business Intelligence -->
    <path id="bc-p-doc-bi" d="M366.8,234.8 Q405,280 443.7,311.7" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Knowledge → Compliance & Governance -->
    <path id="bc-p-kb-comp" d="M306.0,273.9 Q395,270 470.4,210.5" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.1" stroke-width="1"/>
    <!-- Knowledge → Cost Efficiency -->
    <path id="bc-p-kb-cost" d="M255.6,284.0 Q185,310 122.8,317.3" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.1" stroke-width="1"/>

    <!-- Cross connections (6% opacity, 0.7px) -->
    <!-- Agents → Compliance -->
    <path d="M311.9,157.7 Q400,165 466.3,187.1" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.06" stroke-width="0.7"/>
    <!-- Workflows → Revenue -->
    <path d="M195.3,193.6 Q155,135 127.4,86.7" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.06" stroke-width="0.7"/>
    <!-- Documents → Customer Success -->
    <path d="M367.6,195.9 Q410,150 436.6,89.2" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.06" stroke-width="0.7"/>
    <!-- Knowledge → Business Intelligence -->
    <path d="M304.2,284.4 Q370,310 439.3,321.5" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.06" stroke-width="0.7"/>
  </g>

  <!-- ═══ CONNECTIONS: Inner ↔ Inner (dashed diamond, edge-terminated) ═══ -->
  <g class="svg-reveal svg-reveal-d4">
    <line x1="255.7" y1="175.8" x2="229.7" y2="198.1" class="bc-inner-conn" stroke="var(--svg-accent-blue)" stroke-opacity="0.08" stroke-width="0.8"/>
    <line x1="304.3" y1="175.8" x2="330.3" y2="198.1" class="bc-inner-conn" stroke="var(--svg-accent-blue)" stroke-opacity="0.08" stroke-width="0.8"/>
    <line x1="229.7" y1="231.9" x2="260.3" y2="258.1" class="bc-inner-conn" stroke="var(--svg-accent-teal)" stroke-opacity="0.06" stroke-width="0.8"/>
    <line x1="330.3" y1="231.9" x2="299.7" y2="258.1" class="bc-inner-conn" stroke="var(--svg-accent-purple)" stroke-opacity="0.06" stroke-width="0.8"/>
  </g>

  <!-- ═══ PARTICLES (flowing along bezier paths) ═══ -->
  <g class="svg-reveal svg-reveal-d8">
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-blue)" opacity="0.7">
      <animateMotion dur="4s" repeatCount="indefinite"><mpath href="#bc-p-ag-rev"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2" fill="var(--svg-accent-blue)" opacity="0.5">
      <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#bc-p-ag-cus"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-teal)" opacity="0.6">
      <animateMotion dur="4.5s" repeatCount="indefinite"><mpath href="#bc-p-wf-ops"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2" fill="var(--svg-accent-teal)" opacity="0.5">
      <animateMotion dur="5.5s" repeatCount="indefinite"><mpath href="#bc-p-wf-cost"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-purple)" opacity="0.6">
      <animateMotion dur="4.2s" repeatCount="indefinite"><mpath href="#bc-p-doc-bi"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2" fill="var(--svg-accent-orange)" opacity="0.6">
      <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#bc-p-kb-comp"/></animateMotion>
    </circle>
    <circle class="bc-particle" r="2.5" fill="var(--svg-accent-orange)" opacity="0.5">
      <animateMotion dur="4.8s" repeatCount="indefinite"><mpath href="#bc-p-kb-cost"/></animateMotion>
    </circle>
  </g>

  <!-- ═══ INNER NODES: Stagent Product Entities ═══ -->

  <!-- Agents (top center — hero node) -->
  <g class="svg-reveal svg-reveal-d1 bc-drift" style="animation: bc-drift-5 38s ease-in-out infinite">
    <circle class="bc-halo" cx="280" cy="155" r="32" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.15" stroke-width="0.5">
      <animate attributeName="r" values="32;35;32" dur="4s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.15;0.06;0.15" dur="4s" repeatCount="indefinite"/>
    </circle>
    <circle cx="280" cy="155" r="32" fill="url(#bc-sphere-blue)" stroke="var(--svg-accent-blue)" stroke-opacity="0.4" stroke-width="1.2" filter="url(#bc-glow)"/>
    <!-- Bot icon -->
    <g transform="translate(280,155) scale(1.6)">
      <rect x="-10" y="-4" width="20" height="14" rx="3.5" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1.1" vector-effect="non-scaling-stroke"/>
      <circle cx="-4" cy="3" r="1.8" fill="var(--svg-accent-blue)"/>
      <circle cx="4" cy="3" r="1.8" fill="var(--svg-accent-blue)"/>
      <line x1="0" y1="-4" x2="0" y2="-9" stroke="var(--svg-accent-blue)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <circle cx="0" cy="-10.5" r="1.3" fill="var(--svg-accent-blue)"/>
    </g>
    <!-- Label below circle -->
    <text x="280" y="198" text-anchor="middle" fill="var(--svg-accent-blue)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Agents</text>
  </g>

  <!-- Workflows (center-left) -->
  <g class="svg-reveal svg-reveal-d2 bc-drift" style="animation: bc-drift-6 35s ease-in-out infinite">
    <circle class="bc-halo" cx="210" cy="215" r="26" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="210" cy="215" r="26" fill="url(#bc-sphere-teal)" stroke="var(--svg-accent-teal)" stroke-opacity="0.4" stroke-width="1"/>
    <!-- Fork/branch icon -->
    <g transform="translate(210,215) scale(1.3)">
      <path d="M-8,0 L0,0 L8,-6" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.2" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <path d="M0,0 L8,6" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.2" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <circle cx="8" cy="-6" r="1.5" fill="var(--svg-accent-teal)"/>
      <circle cx="8" cy="6" r="1.5" fill="var(--svg-accent-teal)"/>
      <circle cx="-8" cy="0" r="1.5" fill="var(--svg-accent-teal)"/>
    </g>
    <!-- Label below circle -->
    <text x="210" y="252" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Workflows</text>
  </g>

  <!-- Documents (center-right) -->
  <g class="svg-reveal svg-reveal-d3 bc-drift" style="animation: bc-drift-5 40s ease-in-out infinite">
    <circle class="bc-halo" cx="350" cy="215" r="26" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="4.5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="4.5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="350" cy="215" r="26" fill="url(#bc-sphere-purple)" stroke="var(--svg-accent-purple)" stroke-opacity="0.4" stroke-width="1"/>
    <!-- Document icon -->
    <g transform="translate(350,215) scale(1.3)">
      <rect x="-6" y="-9" width="12" height="18" rx="1.5" fill="none" stroke="var(--svg-accent-purple)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="-4" x2="3" y2="-4" stroke="var(--svg-accent-purple)" stroke-width="0.8" stroke-opacity="0.6" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="0" x2="2" y2="0" stroke="var(--svg-accent-purple)" stroke-width="0.8" stroke-opacity="0.6" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="4" x2="0" y2="4" stroke="var(--svg-accent-purple)" stroke-width="0.8" stroke-opacity="0.6" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Label below circle -->
    <text x="350" y="252" text-anchor="middle" fill="var(--svg-accent-purple)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Documents</text>
  </g>

  <!-- Knowledge (bottom center) -->
  <g class="svg-reveal svg-reveal-d4 bc-drift" style="animation: bc-drift-6 36s ease-in-out infinite">
    <circle class="bc-halo" cx="280" cy="275" r="26" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="26;29;26" dur="5.5s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="5.5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="280" cy="275" r="26" fill="url(#bc-sphere-orange)" stroke="var(--svg-accent-orange)" stroke-opacity="0.4" stroke-width="1"/>
    <!-- Lightbulb icon -->
    <g transform="translate(280,275) scale(1.3)">
      <circle cx="0" cy="-2" r="6" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <line x1="-3" y1="6" x2="3" y2="6" stroke="var(--svg-accent-orange)" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
      <line x1="-2" y1="8.5" x2="2" y2="8.5" stroke="var(--svg-accent-orange)" stroke-width="0.8" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Label below circle -->
    <text x="280" y="312" text-anchor="middle" fill="var(--svg-accent-orange)" font-size="8.5" font-family="var(--font-body)" font-weight="600">Knowledge</text>
  </g>

  <!-- ═══ OUTER NODES: Business Outcomes ═══ -->

  <!-- Revenue Growth (top-left, r=25) -->
  <g class="svg-reveal svg-reveal-d5 bc-drift" style="animation: bc-drift-1 28s ease-in-out infinite">
    <circle class="bc-halo bc-outer-halo" cx="115" cy="65" r="25" fill="none" stroke="var(--svg-accent-blue)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="25;28;25" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="115" cy="65" r="25" fill="url(#bc-sphere-blue)" stroke="var(--svg-accent-blue)" stroke-opacity="0.4" stroke-width="0.8" filter="url(#bc-glow-soft)"/>
    <!-- Trending up icon -->
    <g transform="translate(115,65) scale(1.25)">
      <path d="M-9,5 L-3,-3 L3,1 L9,-7" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
      <path d="M5,-7 L9,-7 L9,-3" fill="none" stroke="var(--svg-accent-blue)" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="115" y="101" text-anchor="middle" fill="var(--svg-accent-blue)" font-size="7.5" font-family="var(--font-body)">Revenue</text>
    <text x="115" y="110" text-anchor="middle" fill="var(--svg-accent-blue)" font-size="6" font-family="var(--font-body)">Growth</text>
  </g>

  <!-- Customer Success (top-right, r=21) -->
  <g class="svg-reveal svg-reveal-d5 bc-drift" style="animation: bc-drift-2 32s ease-in-out infinite">
    <circle class="bc-halo bc-outer-halo" cx="445" cy="70" r="21" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="21;24;21" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="445" cy="70" r="21" fill="url(#bc-sphere-teal)" stroke="var(--svg-accent-teal)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Checkmark icon -->
    <g transform="translate(445,70) scale(1.05)">
      <path d="M-7,0 L-2,5 L8,-6" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="445" y="102" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="7.5" font-family="var(--font-body)">Customer</text>
    <text x="445" y="111" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="6" font-family="var(--font-body)">Success</text>
  </g>

  <!-- Operations Excellence (left, r=19) -->
  <g class="svg-reveal svg-reveal-d6 bc-drift" style="animation: bc-drift-3 25s ease-in-out infinite">
    <circle class="bc-halo bc-outer-halo" cx="70" cy="190" r="19" fill="none" stroke="var(--svg-accent-teal)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="19;22;19" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="70" cy="190" r="19" fill="url(#bc-sphere-teal)" stroke="var(--svg-accent-teal)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Gear icon -->
    <g transform="translate(70,190) scale(0.95)">
      <circle cx="0" cy="0" r="6.5" fill="none" stroke="var(--svg-accent-teal)" stroke-width="1" vector-effect="non-scaling-stroke"/>
      <circle cx="0" cy="0" r="2.5" fill="var(--svg-accent-teal)" opacity="0.5"/>
    </g>
    <!-- Labels below circle -->
    <text x="70" y="220" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="7.5" font-family="var(--font-body)">Operations</text>
    <text x="70" y="229" text-anchor="middle" fill="var(--svg-accent-teal)" font-size="6" font-family="var(--font-body)">Excellence</text>
  </g>

  <!-- Cost Efficiency (bottom-left, r=23) -->
  <g class="svg-reveal svg-reveal-d6 bc-drift" style="animation: bc-drift-4 30s ease-in-out infinite">
    <circle class="bc-halo bc-outer-halo" cx="100" cy="320" r="23" fill="none" stroke="var(--svg-accent-orange)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="23;26;23" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="100" cy="320" r="23" fill="url(#bc-sphere-orange)" stroke="var(--svg-accent-orange)" stroke-opacity="0.4" stroke-width="0.8"/>
    <!-- Down-trend icon -->
    <g transform="translate(100,320) scale(1.15)">
      <path d="M-9,-5 L-3,2 L3,-2 L9,7" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke"/>
      <path d="M5,7 L9,7 L9,3" fill="none" stroke="var(--svg-accent-orange)" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
    </g>
    <!-- Labels below circle -->
    <text x="100" y="354" text-anchor="middle" fill="var(--svg-accent-orange)" font-size="7.5" font-family="var(--font-body)">Cost</text>
    <text x="100" y="363" text-anchor="middle" fill="var(--svg-accent-orange)" font-size="6" font-family="var(--font-body)">Efficiency</text>
  </g>

  <!-- Business Intelligence (bottom-right, r=21) -->
  <g class="svg-reveal svg-reveal-d7 bc-drift" style="animation: bc-drift-1 35s ease-in-out infinite">
    <circle class="bc-halo bc-outer-halo" cx="460" cy="325" r="21" fill="none" stroke="var(--svg-accent-purple)" stroke-opacity="0.12" stroke-width="0.5">
      <animate attributeName="r" values="21;24;21" dur="6s" repeatCount="indefinite"/>
      <animate attributeName="stroke-opacity" values="0.12;0.05;0.12" dur="6s" repeatCount="indefinite"/>
    </circle>
